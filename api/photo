export const config = { runtime: 'edge' };

export default async function handler(req) {
  const headers = {
    'Content-Type': 'application/json',
    'Access-Control-Allow-Origin': '*',
    'Cache-Control': 'public, max-age=86400',
  };

  const { searchParams } = new URL(req.url);
  const q = searchParams.get('q') || '';
  if (!q) return new Response(JSON.stringify({ url: null }), { status: 400, headers });

  try {
    // iNaturalist — 학명 or 영문명으로 검색
    const res = await fetch(
      `https://api.inaturalist.org/v1/taxa?q=${encodeURIComponent(q)}&per_page=1&rank=species`,
      { headers: { 'User-Agent': 'FishMuseumApp/1.0' } }
    );
    if (!res.ok) throw new Error('inat error');
    const data = await res.json();
    const result = data.results?.[0];
    const url = result?.default_photo?.medium_url || result?.default_photo?.url || null;

    return new Response(JSON.stringify({ url, name: result?.name || null }), { status: 200, headers });
  } catch (err) {
    return new Response(JSON.stringify({ url: null, error: err.message }), { status: 500, headers });
  }
}
